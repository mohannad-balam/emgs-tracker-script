CHECK_INTERVAL_MINUTES=30
STATE_FILE=/app/data/visa_tracker_state.json
ALWAYS_EMAIL=true
REQUEST_TIMEOUT=30

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your email here
SMTP_PASSWORD="app password here"
SMTP_USE_TLS=true
EMAIL_SUBJECT_PREFIX=EMGS Tracker

PASSPORTS=AF000000,AF000001,AF000002
EMAILS=example1@gmail.com,example2@gamil.com,example3@gmail.com
NATIONALITY=LY

LOG_LEVEL=INFO
LOG_REQUEST_RESPONSE=true

# Daily summary settings
DAILY_SUMMARY_ENABLED=true
DAILY_SUMMARY_HOUR=23
DAILY_SUMMARY_MINUTE=55
TIMEZONE=Africa/Tripoli

RUN_ONCE=true

ERROR_NOTIFY_ENABLED=false
ERROR_NOTIFY_AFTER_CONSECUTIVE_FAILURES=3
ERROR_NOTIFY_COOLDOWN_HOURS=12